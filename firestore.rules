// This single rule is the entire authorization layer for the product. 
// There is no custom backend server checking permissions. Instead, Firestore 
// itself natively enforces that a user can only ever read or write 
// documents that are located strictly under their own UID.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/runs/{runId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
